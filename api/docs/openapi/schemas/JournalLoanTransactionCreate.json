{
  "components": {
    "schemas": {
      "JournalLoanTransactionCreate": {
        "description": "Composite payload: Journal + one-or-two Loan_Journal rows written atomically.",
        "example": {
          "journal": {
            "action_main": "LoanRepayment",
            "action_main_table": "Loan",
            "action_main_type": "LoanRepayment",
            "action_sub": "LN-001",
            "action_sub_table": "Loan",
            "action_sub_type": "Loan",
            "note": "April mortgage payment",
            "spend_date": "20260401",
            "spend_way": "1",
            "spend_way_table": "Account",
            "spend_way_type": "account",
            "spending": -9200.0,
            "vesting_month": "202604"
          },
          "loan_detail": {
            "excute_date": "20260401",
            "interest": 1200.0,
            "loan_id": "LN-001",
            "memo": "April payment",
            "principal": 8000.0
          }
        },
        "properties": {
          "journal": {
