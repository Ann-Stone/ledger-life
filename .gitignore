# Secrets — never commit real env files, local databases, or raw data dumps.
# (Tracked exceptions like *.env.example / view/.env.production keep their suffix
#  and are unaffected; the anonymized test fixture *.db lives under api/tests.)
.env
.env.local
.env.*.local
*.sqlite
*.sqlite3
private_data.sql
ledger.db
ledger.csv
